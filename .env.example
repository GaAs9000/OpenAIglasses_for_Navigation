# ============================================================
# AI Glass Navigation - Environment Variables
# 复制为 .env 并填入实际值: cp .env.example .env
# ============================================================

# ---- 必填：阿里云 DashScope API Key ----
DASHSCOPE_API_KEY=sk-your-api-key-here

# ---- 设备选择 (auto = cuda > mps > cpu) ----
# AIGLASS_DEVICE=auto

# ---- 模型路径（默认使用 model/ 目录，通常不需要改）----
# BLIND_PATH_MODEL=model/yolo-seg.pt
# OBSTACLE_MODEL=model/yoloe-11l-seg.pt
# YOLOE_MODEL_PATH=model/yoloe-11l-seg.pt
# TRAFFICLIGHT_MODEL=model/trafficlight.pt
# YOLO_MODEL_PATH=model/shoppingbest5.pt
# HAND_TASK_PATH=model/hand_landmarker.task

# ---- 推理参数 ----
# AIGLASS_AMP=bf16            # 混合精度: bf16 / fp16 / off (仅CUDA有效)
# AIGLASS_GPU_SLOTS=2         # GPU 并发推理上限
# AIGLASS_OBS_CONF=0.25       # 障碍物检测置信度
# AIGLASS_OBS_INTERVAL=15     # 障碍物检测间隔（帧）

# ---- 盲道导航 ----
# AIGLASS_MASK_MIN_AREA=1500  # 最小掩码面积
# AIGLASS_MASK_MORPH=3        # 形态学核大小
# AIGLASS_STRAIGHT_INTERVAL=4.0   # 直行播报间隔（秒）
# AIGLASS_DIRECTION_INTERVAL=3.0  # 方向播报间隔（秒）
# AIGLASS_PANEL_SCALE=0.65    # 导航面板缩放

# ---- 过街辅助 ----
# CROSSWALK_MIN_CONF=0.3      # 斑马线最低置信度
# CROSSWALK_MIN_AREA=5000     # 斑马线最小面积
# CROSSWALK_ANGLE_THRESH_DEG=5.0  # 对准角度阈值

# ---- 语音/音频 ----
# INTERRUPT_KEYWORDS=停下,别说了,停止
# AIGLASS_COMPRESS_AUDIO=1    # 启用音频压缩
# AIGLASS_COMPRESS_TYPE=adpcm # 压缩格式

# ---- 字体 ----
# AIGLASS_CJK_FONT=           # 手动指定 CJK 字体路径（通常自动检测）

# ---- 调试 ----
# ASR_DEBUG_RAW=0
# AIGLASS_SIMULATE_TRAFFIC_LIGHT=0
# AIGLASS_DEBUG_TRAFFIC_LIGHT=0
